# Base de données PostgreSQL + pgvector
DATABASE_URL="postgresql://savoir_ia:savoir_ia_secret@localhost:5432/savoir_ia"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-..."

# Auth.js v5 — secret obligatoire (générer avec: openssl rand -base64 32)
AUTH_SECRET="changez-moi-en-production"

# OAuth — GitHub (https://github.com/settings/developers)
AUTH_GITHUB_ID="votre-github-client-id"
AUTH_GITHUB_SECRET="votre-github-client-secret"

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID="votre-google-client-id"
AUTH_GOOGLE_SECRET="votre-google-client-secret"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mode mock LLM — si true, les agents retournent des réponses prédéfinies sans appeler Anthropic
MOCK_LLM=false
